# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (DALL-E 3)
OPENAI_API_KEY=your_openai_api_key_here

# YouTube credentials (for Playwright login)
YT_EMAIL=your_youtube_email@gmail.com
YT_PASSWORD=your_youtube_password_here

# Google Cloud Storage
GCS_BUCKET=your_gcs_bucket_name_here
GCP_PROJECT=your_gcp_project_id

# Cloud Run endpoint (used by local_scraper.py)
CLOUD_RUN_URL=https://your-cloud-run-url.run.app

# Pipeline config (optional overrides)
PTT_BOARD=Stock
PTT_PUSH_THRESHOLD=30
MAX_POSTS_PER_RUN=1
GEMINI_MODEL=gemini-2.5-flash
